{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_note": "Project X (SEC Comment Letter). shared-utils 는 read-only (cross-repo). SEC 직접 호출 금지 (coordination daemon 사용). 2026-04-26: portfolio-coordination/mailbox cross-repo write 허용 (메일박스 호스팅), 보호 경로 deny 정밀화. checkpoints/ 도 write 허용 (CLAUDE.md 의 daily checkpoint 의무).",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash",
      "Edit(./**)",
      "Write(./**)",
      "WebSearch",
      "WebFetch",

      "Bash(mkdir -p ./:*)",
      "Bash(mkdir ./:*)",
      "Bash(touch ./:*)",
      "Bash(cp:./**)",
      "Bash(mv:./**)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(find:*)",

      "Bash(uv:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",

      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",

      "Edit(D:/vscode/portfolio-coordination/mailbox/**)",
      "Write(D:/vscode/portfolio-coordination/mailbox/**)",
      "Edit(D:/vscode/portfolio-coordination/checkpoints/**)",
      "Write(D:/vscode/portfolio-coordination/checkpoints/**)",

      "Task",
      "TodoWrite"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(del:*)",
      "Bash(unlink:*)",
      "Bash(shred:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",

      "Bash(git clean:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git branch -D:*)",

      "Edit(D:/vscode/portfolio-coordination/scripts/**)",
      "Write(D:/vscode/portfolio-coordination/scripts/**)",
      "Edit(D:/vscode/portfolio-coordination/shared-utils/**)",
      "Write(D:/vscode/portfolio-coordination/shared-utils/**)",
      "Edit(D:/vscode/portfolio-coordination/sec-data/**)",
      "Write(D:/vscode/portfolio-coordination/sec-data/**)",
      "Edit(D:/vscode/portfolio-coordination/CLAUDE.md)",
      "Write(D:/vscode/portfolio-coordination/CLAUDE.md)",
      "Edit(D:/vscode/portfolio-coordination/README.md)",
      "Write(D:/vscode/portfolio-coordination/README.md)",
      "Edit(D:/vscode/portfolio-coordination/.claude/**)",
      "Write(D:/vscode/portfolio-coordination/.claude/**)",
      "Edit(D:/vscode/portfolio-coordination/openrouter-config.yaml)",
      "Write(D:/vscode/portfolio-coordination/openrouter-config.yaml)",
      "Edit(D:/vscode/portfolio-coordination/pyproject.toml)",
      "Write(D:/vscode/portfolio-coordination/pyproject.toml)",
      "Edit(D:/vscode/portfolio-coordination/mailbox/_meta/**)",
      "Write(D:/vscode/portfolio-coordination/mailbox/_meta/**)",
      "Edit(D:/vscode/portfolio-coordination/mailbox/SCHEMA.md)",
      "Write(D:/vscode/portfolio-coordination/mailbox/SCHEMA.md)",

      "Edit(D:/vscode/activist-intent-llm/**)",
      "Write(D:/vscode/activist-intent-llm/**)",
      "Edit(D:/vscode/factor-zoo-decay-audit/**)",
      "Write(D:/vscode/factor-zoo-decay-audit/**)",
      "Edit(D:/vscode/sin-controversy-pilot/**)",
      "Write(D:/vscode/sin-controversy-pilot/**)",

      "Edit(./.env)",
      "Write(./.env)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/vscode/portfolio-coordination/scripts/check-mailbox.sh sec_comment_letter_alpha"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/vscode/portfolio-coordination/scripts/check-mailbox-incremental.sh sec_comment_letter_alpha"
          }
        ]
      }
    ]
  }
}
