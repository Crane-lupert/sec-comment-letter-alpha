      "Bash(touch ./:*)",
      "Bash(cp:./**)",
      "Bash(mv:./**)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
